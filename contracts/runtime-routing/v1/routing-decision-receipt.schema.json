{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://simplicio.dev/contracts/runtime-routing/v1/routing-decision-receipt.schema.json",
  "title": "simplicio.routing-decision-receipt/v1",
  "type": "object",
  "required": [
    "schema",
    "policy_version",
    "registry_hash",
    "requirements",
    "candidates",
    "selected",
    "blocked",
    "block_reason",
    "timestamp",
    "previous_route_id",
    "fallback_reason_code",
    "fallback_decision",
    "retry_backoff_seconds"
  ],
  "properties": {
    "schema": { "const": "simplicio.routing-decision-receipt/v1" },
    "policy_version": { "type": "string", "minLength": 1 },
    "registry_hash": {
      "type": "string",
      "description": "sha256 content hash of the ModelCapabilityRegistry's declared entries (not probe results); candidates can be re-verified against the exact registry state that produced this decision."
    },
    "requirements": {
      "type": "object",
      "required": [
        "role",
        "required_capabilities",
        "preferred_capabilities",
        "allowed_providers",
        "denied_providers",
        "os",
        "arch",
        "context_window_min",
        "require_probe_available",
        "independent_review"
      ],
      "properties": {
        "role": { "enum": ["planner", "executor", "reviewer", "tester"] },
        "required_capabilities": { "type": "array", "items": { "type": "string" } },
        "preferred_capabilities": { "type": "array", "items": { "type": "string" } },
        "allowed_providers": { "type": "array", "items": { "type": "string" } },
        "denied_providers": { "type": "array", "items": { "type": "string" } },
        "os": { "type": "string" },
        "arch": { "type": "string" },
        "context_window_min": { "type": "integer", "minimum": 0 },
        "require_probe_available": { "type": "boolean" },
        "independent_review": { "type": "boolean" }
      }
    },
    "candidates": {
      "type": "array",
      "description": "Every candidate the router considered, including entries eliminated by the registry's eligibility filter and entries rejected by router policy (e.g. independent_review).",
      "items": {
        "type": "object",
        "required": ["runtime", "provider", "model_id", "score", "status"],
        "properties": {
          "runtime": { "type": "string" },
          "provider": { "type": "string" },
          "model_id": { "type": "string" },
          "score": {
            "type": ["integer", "null"],
            "description": "null when the candidate was eliminated before scoring (registry-level eligibility reason)."
          },
          "status": { "enum": ["selected", "rejected"] },
          "reason_code": {
            "type": "string",
            "description": "Present when status=rejected.",
            "enum": [
              "missing_capability",
              "context_limit",
              "runtime_unavailable",
              "auth_missing",
              "policy_denied",
              "budget_exceeded",
              "device_incompatible",
              "capacity_exhausted"
            ]
          }
        }
      }
    },
    "selected": {
      "description": "The chosen runtime/provider/model, or null when blocked=true.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["runtime", "provider", "model_id", "score"],
          "properties": {
            "runtime": { "type": "string" },
            "provider": { "type": "string" },
            "model_id": { "type": "string" },
            "score": { "type": "integer" }
          }
        }
      ]
    },
    "blocked": {
      "type": "boolean",
      "description": "True iff no candidate satisfied mandatory requirements/policy; the router never silently falls back to a default."
    },
    "block_reason": { "type": "string" },
    "timestamp": { "type": "string" },
    "previous_route_id": {
      "type": "string",
      "description": "Links this decision to the route it supersedes when produced by route_with_fallback(); empty for a first-hop decision."
    },
    "fallback_reason_code": {
      "type": "string",
      "description": "The failure reason code (e.g. timeout, rate_limited, auth_missing) that triggered this fallback hop; empty for a first-hop decision."
    },
    "fallback_decision": {
      "description": "retry_same_route / fallback_route / terminal, or null for a first-hop decision.",
      "oneOf": [
        { "type": "null" },
        { "enum": ["retry_same_route", "fallback_route", "terminal"] }
      ]
    },
    "retry_backoff_seconds": {
      "description": "Deterministic backoff+jitter delay before the caller should act on this receipt, or null when no backoff applies (first-hop or terminal decisions).",
      "oneOf": [
        { "type": "null" },
        { "type": "number", "minimum": 0 }
      ]
    }
  }
}
