{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://simplicio.dev/contracts/runtime-routing/v1/runtime-execution-receipt.schema.json",
  "title": "simplicio.runtime-execution-receipt/v1",
  "description": "Records what actually happened when a routed runtime executed (or failed to) -- distinct from routing-decision-receipt.schema.json, which only records the decision. Fields that were not genuinely measured are the literal string 'UNAVAILABLE', never fabricated.",
  "type": "object",
  "required": [
    "schema",
    "route_id",
    "previous_route_id",
    "fallback_reason_code",
    "requested",
    "resolved",
    "driver",
    "session",
    "argv_redacted",
    "env_allowlist",
    "tree",
    "exit_status",
    "duration_seconds",
    "stop_reason",
    "stream_hashes",
    "usage",
    "evidence_refs",
    "measured_at",
    "receipt_sha"
  ],
  "properties": {
    "schema": { "const": "simplicio.runtime-execution-receipt/v1" },
    "route_id": {
      "type": "string",
      "minLength": 1,
      "description": "Id of the routing-decision-receipt that selected this execution."
    },
    "previous_route_id": {
      "type": "string",
      "description": "Set when this execution followed a fallback hop (model_router.route_with_fallback); empty otherwise."
    },
    "fallback_reason_code": { "type": "string" },
    "requested": { "$ref": "#/definitions/model_ref" },
    "resolved": {
      "description": "What the driver actually observed running; may equal 'UNAVAILABLE'/verified=false when the tool never exposes the model it used.",
      "allOf": [{ "$ref": "#/definitions/model_ref" }]
    },
    "driver": {
      "type": "object",
      "required": ["name", "binary", "version", "identity_verified"],
      "properties": {
        "name": { "type": "string" },
        "binary": { "type": "string" },
        "version": { "type": "string" },
        "identity_verified": { "type": "boolean" }
      }
    },
    "session": {
      "type": "object",
      "required": ["worker_id", "device_id", "attempt_id", "lease_id", "fence_token"],
      "properties": {
        "worker_id": { "type": "string" },
        "device_id": { "type": "string" },
        "attempt_id": { "type": "string", "minLength": 1 },
        "lease_id": { "type": "string" },
        "fence_token": { "type": "string" }
      }
    },
    "argv_redacted": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Structured argv actually invoked, secrets already redacted by the caller. Never a shell string built from task data."
    },
    "env_allowlist": { "type": "array", "items": { "type": "string" } },
    "tree": {
      "type": "object",
      "required": ["base_sha", "head_sha", "changed_paths"],
      "properties": {
        "base_sha": { "type": "string" },
        "head_sha": { "type": "string" },
        "changed_paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "exit_status": { "type": ["integer", "null"] },
    "duration_seconds": { "type": ["number", "null"], "minimum": 0 },
    "stop_reason": {
      "enum": ["completed", "timeout", "cancelled", "error", "circuit_open", "budget_exceeded"]
    },
    "stream_hashes": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "e.g. {\"stdout\": sha256, \"stderr\": sha256}."
    },
    "usage": {
      "type": "object",
      "required": ["tokens", "cost_usd", "latency_seconds"],
      "properties": {
        "tokens": { "oneOf": [{ "type": "number" }, { "const": "UNAVAILABLE" }] },
        "cost_usd": { "oneOf": [{ "type": "number" }, { "const": "UNAVAILABLE" }] },
        "latency_seconds": { "oneOf": [{ "type": "number" }, { "const": "UNAVAILABLE" }] }
      }
    },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "measured_at": { "type": "string" },
    "receipt_sha": {
      "type": "string",
      "description": "sha256 canonical content hash of every other field, recomputed by receipt_verifier.verify_receipt() for tamper detection."
    }
  },
  "definitions": {
    "model_ref": {
      "type": "object",
      "required": ["runtime", "provider", "model_id", "verified"],
      "properties": {
        "runtime": { "type": "string" },
        "provider": { "type": "string" },
        "model_id": { "type": "string" },
        "verified": { "type": "boolean" }
      }
    }
  }
}
