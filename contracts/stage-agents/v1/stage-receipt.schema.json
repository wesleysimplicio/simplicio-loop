{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simplicio.dev/contracts/stage-agents/v1/stage-receipt.schema.json",
  "title": "simplicio.stage-receipt/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "agent_instance_id", "role_id", "role_version", "stage_id", "stage_version",
    "run_id", "task_id", "work_item_id", "attempt_id", "fence", "plan_revision",
    "status", "reason_code", "input_hash", "output_hash", "context_hash", "manifest_hash",
    "evidence_refs", "commands", "artifact_refs", "created_at", "observed_at", "ttl_seconds",
    "previous_receipt_hashes", "integrity_hash", "acs_covered", "next_stage_recommendation"
  ],
  "properties": {
    "schema": { "const": "simplicio.stage-receipt/v1" },
    "agent_instance_id": { "type": "string" },
    "role_id": { "type": "string" },
    "role_version": { "type": "string" },
    "stage_id": { "type": "string" },
    "stage_version": { "type": "string" },
    "run_id": { "type": "string" },
    "task_id": { "type": "string" },
    "work_item_id": { "type": "string" },
    "attempt_id": { "type": "string" },
    "fence": { "type": "integer", "minimum": 0 },
    "plan_revision": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["PASSED", "FAILED", "BLOCKED", "CANCELLED", "TIMED_OUT", "STALE"] },
    "reason_code": { "type": "string" },
    "input_hash": { "type": "string" },
    "output_hash": { "type": "string" },
    "context_hash": { "type": "string" },
    "manifest_hash": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cmd", "exit_code"],
        "properties": {
          "cmd": { "type": "string" },
          "exit_code": { "type": "integer" }
        }
      }
    },
    "artifact_refs": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string" },
    "observed_at": { "type": "string" },
    "ttl_seconds": { "type": "integer", "minimum": 1 },
    "previous_receipt_hashes": { "type": "array", "items": { "type": "string" } },
    "integrity_hash": { "type": "string" },
    "acs_covered": { "type": "array", "items": { "type": "string" } },
    "next_stage_recommendation": { "type": "string" }
  }
}
