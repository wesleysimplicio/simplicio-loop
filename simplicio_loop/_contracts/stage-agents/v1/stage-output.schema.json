{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://simplicio.dev/contracts/stage-agents/v1/stage-output.schema.json",
  "title": "simplicio.stage-output/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema","run_id","task_id","stage_id","attempt_id","attempt_ordinal","fence","plan_revision","status","payload"],
  "properties": {"schema": {"const": "simplicio.stage-output/v1"},"run_id": {"type": "string","minLength": 1},"task_id": {"type": "string","minLength": 1},"stage_id": {"type": "string","pattern": "^[a-z][a-z0-9_-]*$"},"attempt_id": {"type": "string","minLength": 1},"attempt_ordinal": {"type": "integer","minimum": 1},"fence": {"type": "string","minLength": 1},"plan_revision": {"type": "integer","minimum": 0},"status": {"enum": ["pass","fail","blocked","cancelled","timed_out","stale"]},"payload": {"type": "object","additionalProperties": true}}
}
