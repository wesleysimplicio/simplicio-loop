.simplicio/
*.egg-info/
__pycache__/
dist/
.orchestrator/*
# Exception: the committed first savings-harness snapshot pair (#92) is real measured evidence,
# not scratch runtime state — keep it tracked even though the rest of .orchestrator/ is ignored.
# (git can't re-include a path under an EXCLUDED parent dir, hence `.orchestrator/*` here instead
# of `.orchestrator/` — see `git help gitignore`.)
!.orchestrator/savings/
*.db
.serena/
.agents/
.playwright-cli/
.playwright-mcp/
output/
build/

# Rust build artifacts
rust/target/

# Generated media (#116): video/ SOURCE (build_*.py, storyboard.master.json, lang/*, hyperframes
# HTML composition sources, render.sh, README) stays tracked; only the rendered/ephemeral OUTPUT
# is ignored — regenerate it with `bash video/render.sh` (see video/README.md).
video/out/
**/_audio_tmp/

# Packaged deliverables zip (generated artifact, not source) — see #116.
simplicio-loop_deliverables.zip

.receipts/

# Simplicio Runtime edit/validate execution receipts (local evidence, not source)

# Coverage data (pytest-cov / coverage.py) — regenerated by
# `pytest --cov=simplicio_loop --cov-report=term-missing`, not source.
.coverage
.coverage.*
htmlcov/

# Transient git worktrees created by Workflow/Agent isolation:'worktree' runs.
.claude/worktrees/
d/
