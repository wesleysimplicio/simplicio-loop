#!/usr/bin/env bash
# simplicio-engine — Simplicio capture engine entrypoint (native, self-contained).
#
# Runs the self-contained native engine (engine/simplicio_engine.py — proxy + doctor +
# memory stats, no external dependency). This is the single place that resolves the engine.
set -euo pipefail

_here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_native="$_here/../engine/simplicio_engine.py"
_py="${SIMPLICIO_PYTHON:-python3}"

# Honor an explicit override; otherwise run the native module that ships with the repo.
_engine="${SIMPLICIO_ENGINE_BIN:-}"
if [ -n "${_engine}" ]; then
  exec "${_engine}" "$@"
fi
if [ -f "$_native" ]; then
  exec "$_py" "$_native" "$@"
fi
echo "simplicio-engine: native engine module missing ($_native)" >&2
exit 127
